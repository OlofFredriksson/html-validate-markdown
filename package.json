{
  "name": "html-validate-markdown",
  "version": "6.0.0",
  "description": "Transform Html blocks in Markdown files for use with html-validate.",
  "keywords": [
    "html",
    "lint",
    "html-validate"
  ],
  "homepage": "https://github.com/OlofFredriksson/html-validate-markdown",
  "bugs": {
    "url": "https://github.com/OlofFredriksson/html-validate-markdown/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OlofFredriksson/html-validate-markdown.git"
  },
  "license": "MIT",
  "author": "Olof",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "tsc --build",
    "build": "run-s build:lib build:esm-dts build:cjs-dts",
    "build:cjs-dts": "dts-bundle-generator --project tsconfig.cjs.json --no-banner -o dist/index.d.cts src/cjs-shim.ts",
    "build:esm-dts": "dts-bundle-generator --no-banner -o dist/index.d.mts src/transform.ts",
    "build:lib": "node build.mjs",
    "lint": "eslint src/*.ts test/*.ts && npm run prettier:check",
    "prettier:check": "prettier . --check",
    "prettier:write": "prettier . --write",
    "test": "jest",
    "postversion": "git push --follow-tags"
  },
  "commitlint": {
    "extends": "@forsakringskassan/commitlint-config/no-jira"
  },
  "prettier": "@forsakringskassan/prettier-config",
  "release": {
    "extends": "@forsakringskassan/semantic-release-config"
  },
  "jest": {
    "preset": "@forsakringskassan/jest-config"
  },
  "devDependencies": {
    "@forsakringskassan/commitlint-config": "3.6.9",
    "@forsakringskassan/eslint-config": "15.0.18",
    "@forsakringskassan/eslint-config-cli": "15.0.0",
    "@forsakringskassan/eslint-config-jest": "15.0.0",
    "@forsakringskassan/eslint-config-typescript": "15.0.19",
    "@forsakringskassan/jest-config": "30.3.2",
    "@forsakringskassan/prettier-config": "3.7.2",
    "@sidvind/build-scripts": "1.0.0",
    "@tsconfig/node22": "22.0.5",
    "@types/jest": "30.0.0",
    "@types/node": "22.19.21",
    "dts-bundle-generator": "9.5.1",
    "esbuild": "0.28.1",
    "html-validate": "11.5.3",
    "npm-run-all2": "9.0.2",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "html-validate": "^8.26.0 || ^9.0.0 || ^10.0.0 || ^11.0.0"
  },
  "engines": {
    "node": "^22.0.0 || >= 24.0.0"
  }
}
